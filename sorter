#include <Servo.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <SoftwareSerial.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

Adafruit_SSD1306 display(128,64,&Wire,-1);

SoftwareSerial BT(10,11);   // RX, TX

Servo myServo;

int waterSensor = A0;

int trig = 6;
int echo = 7;

int wetCount = 0;
int dryCount = 0;

bool objectDetected = false;

bool wetAlertSent = false;
bool dryAlertSent = false;

void setup(){

Serial.begin(9600);
BT.begin(9600);

Wire.begin();

myServo.attach(9);
myServo.write(90);

pinMode(trig,OUTPUT);
pinMode(echo,INPUT);

if(!display.begin(SSD1306_SWITCHCAPVCC,0x3C)){
Serial.println("OLED failed");
while(true);
}

display.setTextColor(WHITE);

display.clearDisplay();
display.setTextSize(2);
display.setCursor(15,20);
display.println("SMART BIN");
display.display();

delay(2000);
}

void loop(){

int waterValue = analogRead(waterSensor);
int distance = getDistance();

Serial.print("Water: ");
Serial.print(waterValue);
Serial.print(" Distance: ");
Serial.println(distance);

/* -------- WET WASTE -------- */

if(waterValue > 500){

wetCount++;

showStatus("WET WASTE");

myServo.write(150);
delay(2000);
myServo.write(90);

delay(2000);
}

/* -------- DRY WASTE -------- */

else if(distance < 5 && objectDetected == false){

objectDetected = true;

dryCount++;

showStatus("DRY WASTE");

myServo.write(30);
delay(2000);
myServo.write(90);

delay(2000);
}

if(distance > 8){
objectDetected = false;
}

updateDisplay();

sendBluetoothAlerts();

delay(200);
}

int getDistance(){

digitalWrite(trig,LOW);
delayMicroseconds(2);

digitalWrite(trig,HIGH);
delayMicroseconds(10);
digitalWrite(trig,LOW);

long duration = pulseIn(echo,HIGH,30000);

int distance = duration * 0.034 / 2;

return distance;
}

/* -------- OLED DISPLAY -------- */

void updateDisplay(){

display.clearDisplay();

display.setTextSize(2);

display.setCursor(0,0);
display.print("W:");
display.print(wetCount);

display.setCursor(70,0);
display.print("D:");
display.print(dryCount);

display.display();
}

void showStatus(String message){

display.clearDisplay();

display.setTextSize(2);

display.setCursor(0,0);
display.print("W:");
display.print(wetCount);

display.setCursor(70,0);
display.print("D:");
display.print(dryCount);

display.setCursor(0,35);
display.println(message);

display.display();
}

/* -------- BLUETOOTH ALERT -------- */

void sendBluetoothAlerts(){

if(wetCount >= 5 && wetAlertSent == false){

BT.println("VERDEON ALERT");
BT.println("WET WASTE FULL");

Serial.println("Wet alert sent");

wetAlertSent = true;
}

if(dryCount >= 5 && dryAlertSent == false){

BT.println("VERDEON ALERT");
BT.println("DRY WASTE FULL");

Serial.println("Dry alert sent");

dryAlertSent = true;
}

}
