#include <Servo.h>

Servo myServo;

int waterSensor = A0;
int trig = 6;
int echo = 7;

int dryCount = 0;

void setup() {

  Serial.begin(9600);

  myServo.attach(9);
  myServo.write(90);

  pinMode(trig, OUTPUT);
  pinMode(echo, INPUT);
}

void loop() {

  int waterValue = analogRead(waterSensor);
  Serial.println(waterValue);

  if (waterValue > 500) {   // WET WASTE
    myServo.write(150);
    delay(2000);
    myServo.write(90);
  }

  else {   // DRY WASTE
    myServo.write(30);
    delay(2000);
    myServo.write(90);

    if (detectObject()) {
      dryCount++;
      Serial.print("Dry waste count: ");
      Serial.println(dryCount);
    }
  }

  delay(1000);
}

bool detectObject() {

  digitalWrite(trig, LOW);
  delayMicroseconds(2);

  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);

  long duration = pulseIn(echo, HIGH);

  int distance = duration * 0.034 / 2;

  if (distance < 10) {
    delay(1000);
    return true;
  }

  return false;
}
