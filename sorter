#include <Servo.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

Servo myServo;

int waterSensor = A0;

int trig = 6;
int echo = 7;

int wetCount = 0;
int dryCount = 0;

bool objectDetected = false;
bool wetDetected = false;

void setup() {

  Serial.begin(9600);

  myServo.attach(9);
  myServo.write(90);

  pinMode(trig, OUTPUT);
  pinMode(echo, INPUT);

  if(!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED failed");
    while(true);
  }

  display.clearDisplay();
  display.setTextSize(2);
  display.setCursor(10,20);
  display.println("SMART BIN");
  display.display();

  delay(2000);
}

void loop() {

  int waterValue = analogRead(waterSensor);
  int distance = getDistance();

  Serial.print("Water: ");
  Serial.print(waterValue);
  Serial.print("  Distance: ");
  Serial.println(distance);

  // WET WASTE DETECTION
  if(waterValue > 500 && wetDetected == false){

    wetDetected = true;

    Serial.println("Wet Waste Detected");

    wetCount++;

    showWet();

    myServo.write(150);
    delay(2000);
    myServo.write(90);

    delay(2000);
  }

  // DRY WASTE DETECTION
  else if(distance < 5 && objectDetected == false){

    objectDetected = true;

    Serial.println("Dry Waste Detected");

    dryCount++;

    showDry();

    myServo.write(30);
    delay(2000);
    myServo.write(90);

    delay(2000);
  }

  if(distance > 8){
    objectDetected = false;
  }

  if(waterValue < 400){
    wetDetected = false;
  }

  delay(200);
}

int getDistance(){

  digitalWrite(trig, LOW);
  delayMicroseconds(2);

  digitalWrite(trig, HIGH);
  delayMicroseconds(10);
  digitalWrite(trig, LOW);

  long duration = pulseIn(echo, HIGH, 30000);

  int distance = duration * 0.034 / 2;

  return distance;
}

void showWet(){

  display.clearDisplay();

  display.setTextSize(3);
  display.setCursor(0,0);
  display.println("WET");

  display.setCursor(0,30);
  display.println("WASTE");

  display.setTextSize(2);
  display.setCursor(0,54);
  display.print("C:");
  display.print(wetCount);

  display.display();
}

void showDry(){

  display.clearDisplay();

  display.setTextSize(3);
  display.setCursor(0,0);
  display.println("DRY");

  display.setCursor(0,30);
  display.println("WASTE");

  display.setTextSize(2);
  display.setCursor(0,54);
  display.print("C:");
  display.print(dryCount);

  display.display();
}
