#include <Servo.h>

Servo myServo;

int waterSensor = A0;
int waterValue = 0;

void setup() {
  Serial.begin(9600);
  myServo.attach(9);

  myServo.write(90); // default position
}

void loop() {

  waterValue = analogRead(waterSensor);
  Serial.println(waterValue);

  if (waterValue > 500) {
    myServo.write(150);   // move to 150 degrees
    delay(2000);          // stay 2 seconds
    myServo.write(90);    // return to normal
    delay(500);
  }

  else if (waterValue < 500) {
    myServo.write(30);    // move to 30 degrees
    delay(2000);          // stay 2 seconds
    myServo.write(90);    // return to normal
    delay(500);
  }

}
